{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pfbench_scenario_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "dataset_id",
    "scenario_id",
    "source_case",
    "split",
    "grid_reference",
    "base_grid_snapshot",
    "scenario_spec",
    "scenario_input_state",
    "data_quality_flags",
    "powerflow_results",
    "provenance",
    "metadata"
  ],
  "properties": {
    "dataset_id": {"type": "string"},
    "scenario_id": {"type": "string"},
    "source_case": {"type": "string"},
    "split": {"type": "string"},
    "grid_reference": {
      "type": "object",
      "required": [
        "case_name",
        "source_library",
        "base_mva",
        "counts",
        "data_digest",
        "bus_partition_counts"
      ],
      "properties": {
        "case_name": {"type": "string"},
        "source_library": {"type": ["string", "null"]},
        "source_url": {
          "type": ["string", "null"],
          "description": "Pinned upstream tag/commit URL for the source case when available; null means no stable upstream URL was recorded."
        },
        "matpower_case_format_version": {"type": ["string", "null"]},
        "base_mva": {"type": "number"},
        "counts": {"type": "object"},
        "bus_partition_counts": {"type": "object"},
        "data_digest": {"type": "string"}
      },
      "additionalProperties": true
    },
    "base_grid_snapshot": {
      "type": "object",
      "required": ["bus_partition", "buses", "generators", "branches"],
      "properties": {
        "bus_partition": {"type": "object"},
        "buses": {"type": "array", "items": {"$ref": "#/$defs/bus_snapshot"}},
        "generators": {"type": "array", "items": {"$ref": "#/$defs/generator_snapshot"}},
        "branches": {"type": "array"}
      },
      "additionalProperties": false
    },
    "scenario_spec": {
      "type": "object",
      "required": ["scenario_id", "seed", "source_case", "solver_modes", "mutations"],
      "properties": {
        "scenario_id": {"type": "string"},
        "seed": {"type": "integer"},
        "source_case": {"type": "string"},
        "solver_modes": {"type": "array", "items": {"type": "string"}},
        "mutations": {"type": "array"}
      },
      "additionalProperties": true
    },
    "scenario_input_state": {
      "type": "object",
      "required": [
        "bus_partition",
        "buses",
        "generators",
        "branches",
        "bus_loads",
        "generator_setpoints",
        "branch_state",
        "totals"
      ],
      "properties": {
        "bus_partition": {
          "type": "object",
          "required": ["slack_bus_ids", "pv_bus_ids", "pq_bus_ids"]
        },
        "buses": {"type": "array", "items": {"$ref": "#/$defs/bus_snapshot"}},
        "generators": {"type": "array", "items": {"$ref": "#/$defs/generator_snapshot"}},
        "branches": {"type": "array"},
        "bus_loads": {"type": "array"},
        "generator_setpoints": {"type": "array", "items": {"$ref": "#/$defs/generator_setpoint"}},
        "branch_state": {"type": "array"},
        "totals": {"type": "object"}
      },
      "additionalProperties": false
    },
    "data_quality_flags": {
      "type": "object",
      "required": [
        "base_kv_missing_bus_ids",
        "source_voltage_limit_inconsistency_bus_ids",
        "source_generator_q_limit_inconsistency_gen_ids",
        "missing_branch_rating_branch_ids",
        "ac_power_balance_residual_mw",
        "dc_power_balance_residual_mw"
      ],
      "properties": {
        "base_kv_missing_bus_ids": {
          "type": "array",
          "items": {"type": "integer"}
        },
        "source_voltage_limit_inconsistency_bus_ids": {
          "type": "array",
          "items": {"type": "integer"}
        },
        "source_generator_q_limit_inconsistency_gen_ids": {
          "type": "array",
          "items": {"type": "integer"}
        },
        "missing_branch_rating_branch_ids": {
          "type": "array",
          "items": {"type": "integer"}
        },
        "ac_power_balance_residual_mw": {"type": "number"},
        "dc_power_balance_residual_mw": {"type": "number"}
      },
      "additionalProperties": false
    },
    "powerflow_results": {
      "type": "object",
      "required": ["ac", "dc"],
      "properties": {
        "ac": {
          "type": "object",
          "required": ["solver_name", "bus_results", "generator_results", "branch_results", "system_summary"],
          "properties": {
            "bus_results": {"type": "array", "items": {"$ref": "#/$defs/bus_result"}},
            "generator_results": {"type": "array", "items": {"$ref": "#/$defs/generator_result"}},
            "system_summary": {"$ref": "#/$defs/system_summary"}
          }
        },
        "dc": {
          "type": "object",
          "required": ["solver_name", "bus_results", "generator_results", "branch_results", "system_summary"],
          "properties": {
            "bus_results": {"type": "array", "items": {"$ref": "#/$defs/bus_result"}},
            "generator_results": {"type": "array", "items": {"$ref": "#/$defs/generator_result"}},
            "system_summary": {"$ref": "#/$defs/system_summary"}
          }
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "dataset_version",
        "generated_at",
        "schema_versions",
        "solver_config_digest",
        "source_library"
      ],
      "properties": {
        "dataset_version": {"type": "string"},
        "generated_at": {"type": "string"},
        "schema_versions": {"type": "object"},
        "solver_config_digest": {"type": "string"},
        "source_library": {"type": ["string", "null"]},
        "source_reference": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "required": [
        "seed",
        "scenario_text",
        "mutation_ops",
        "solver_name_ac",
        "solver_name_dc",
        "solver_config_digest",
        "schema_versions",
        "generated_at",
        "dataset_version"
      ],
      "properties": {
        "seed": {"type": "integer"},
        "scenario_text": {"type": "string"},
        "mutation_ops": {"type": "array", "items": {"type": "string"}},
        "solver_name_ac": {"type": "string"},
        "solver_name_dc": {"type": "string"},
        "solver_config_digest": {"type": "string"},
        "schema_versions": {"type": "object"},
        "generated_at": {"type": "string"},
        "dataset_version": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "bus_snapshot": {
      "type": "object",
      "description": "Bus input metadata. `base_kv` is null when the source case stores 0 as an unspecified nominal voltage; the original value remains in `base_kv_raw` and `base_kv_is_missing`.",
      "properties": {
        "vm_input_pu": {"type": "number"},
        "va_input_deg": {"type": "number"},
        "base_kv": {
          "type": ["number", "null"],
          "description": "Normalized nominal voltage in kV. Null means the source case left this unspecified."
        },
        "base_kv_raw": {
          "type": "number",
          "description": "Raw source-case base_kv field before missing-value normalization."
        },
        "base_kv_is_missing": {
          "type": "boolean",
          "description": "True when the source case used 0 to mean nominal voltage metadata was unspecified."
        }
      },
      "additionalProperties": true
    },
    "generator_snapshot": {
      "type": "object",
      "properties": {
        "q_limit_violated": {
          "type": ["boolean", "null"],
          "description": "Whether the stored reactive output lies outside [qmin_mvar, qmax_mvar]. Null is reserved for records without a reactive-output value."
        }
      },
      "additionalProperties": true
    },
    "generator_setpoint": {
      "type": "object",
      "properties": {
        "q_limit_violated": {
          "type": ["boolean", "null"],
          "description": "Whether the input reactive setpoint lies outside [qmin_mvar, qmax_mvar]. Null is reserved for records without a reactive-output value."
        }
      },
      "additionalProperties": true
    },
    "bus_result": {
      "type": "object",
      "properties": {
        "p_net_injection_mw": {
          "type": "number",
          "description": "Active net injection under the solver sign convention. In AC results this includes modeled bus shunt conductance; in DC results shunt conductance is omitted."
        },
        "q_net_injection_mvar": {
          "type": ["number", "null"],
          "description": "Reactive net injection under the solver sign convention. In AC results this includes modeled bus shunt susceptance. Null in DC results because the DC model omits reactive quantities."
        },
        "shunt_p_demand_mw": {
          "type": "number",
          "description": "Active shunt demand implied by the AC bus shunt conductance model. This is 0.0 in DC results because shunt conductance is omitted."
        },
        "shunt_q_injection_mvar": {
          "type": ["number", "null"],
          "description": "Reactive shunt injection implied by the AC bus shunt model. Null in DC results because shunts are not part of the DC solve."
        }
      },
      "additionalProperties": true
    },
    "generator_result": {
      "type": "object",
      "properties": {
        "qg_mvar": {
          "type": ["number", "null"],
          "description": "Solved reactive output. Null in DC results because the DC model does not solve for reactive power."
        },
        "q_limit_violated": {
          "type": ["boolean", "null"],
          "description": "Whether `qg_mvar` violates [qmin_mvar, qmax_mvar]. Null in DC results because `qg_mvar` is omitted."
        }
      },
      "additionalProperties": true
    },
    "system_summary": {
      "type": "object",
      "properties": {
        "total_gen_q_mvar": {
          "type": ["number", "null"],
          "description": "Total solved reactive generation. Null in DC results."
        },
        "total_shunt_p_demand_mw": {
          "type": "number",
          "description": "Total modeled active shunt demand included in the AC power balance. This is 0.0 when the solver mode omits shunt conductance, such as DC."
        },
        "total_shunt_q_injection_mvar": {
          "type": ["number", "null"],
          "description": "Total modeled shunt reactive injection. Null when the solver mode does not include reactive shunts, such as DC."
        },
        "total_loss_q_mvar": {
          "type": ["number", "null"],
          "description": "Total reactive branch loss. Null in DC results."
        },
        "net_bus_injection_p_mw": {
          "type": "number",
          "description": "Sum of per-bus active net injections under the solver sign convention."
        },
        "net_bus_injection_q_mvar": {
          "type": ["number", "null"],
          "description": "Sum of per-bus reactive net injections. Null in DC results."
        },
        "power_balance_residual_p_mw": {
          "type": "number",
          "description": "Active power balance residual after accounting for generation, load, modeled shunt demand, and branch loss."
        },
        "power_balance_residual_q_mvar": {
          "type": ["number", "null"],
          "description": "Reactive power balance residual after accounting for generation, load, modeled shunt injection, and branch loss. Null in DC results."
        }
      },
      "additionalProperties": true
    }
  }
}
